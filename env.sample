# ==========================================
# OVERWATCH // ENVIRONMENT CONFIGURATION
# ==========================================

# --- SECURITY & RELAY (RENDER) ---
# Used to authenticate incoming webhooks before processing
WEBHOOK_SECRET=generate_strong_random_hash_here
# Port for FastAPI (Render usually defaults to 10000)
PORT=10000 

# --- LLM ANALYTICS ENGINE ---
# Set to 'anthropic' (Claude 3 Opus/Sonnet is highly recommended for JSON parsing) or 'openai'
LLM_PROVIDER=anthropic 
LLM_API_KEY=your_llm_api_key_here

# --- BDA & THERMAL ANOMALIES ---
NASA_FIRMS_API_KEY=your_firms_key_here

# --- OPTICAL & SAR SATELLITE APIs ---
SENTINEL_HUB_CLIENT_ID=your_sentinel_client_id_here
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_client_secret_here
USGS_M2M_USERNAME=your_usgs_username_here
USGS_M2M_PASSWORD=your_usgs_password_here

# --- TACTICAL BASEMAPS (VISUAL VERIFICATION) ---
MAPTILER_API_KEY=your_maptiler_key_here
YANDEX_MAPS_API_KEY=your_yandex_key_here

# --- ASSET TRACKING ---
ADSB_EXCHANGE_API_KEY=your_adsb_key_here
MARINE_TRAFFIC_API_KEY=your_marine_traffic_key_here
