# ==========================================
# OVERWATCH // REPOSITORY IGNORPTION RULES
# ==========================================

# --- SECURITY & CREDENTIALS ---
# Absolutely no keys, tokens, or environment files
.env
.env.local
.env.*.local
auth.py
config.ini
secrets.json
tokens/
cookies.txt
*.pem
*.key

# --- OSINT DATA & INTELLIGENCE ---
# Ignore all scraped data, databases, and raw webhooks
data/
downloads/
exports/
results/
intelligence/
*.db
*.sqlite
*.sqlite3
*.csv
*.jsonl
*.log

# --- PYTHON ENVIRONMENT ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- OS & IDE RESIDUE ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
*.stackdump

# IDEs
.idea/
.vscode/
*.swp
*.swo
